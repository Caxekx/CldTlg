# 1) Токен Telegram-бота из @BotFather
BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE

# 2) Telegram ID админов через запятую. Узнать можно командой /id после первого запуска
ADMIN_IDS=PASTE_YOUR_TELEGRAM_ID_HERE

# 3) Ограничения
MAX_PROMPT_CHARS=6000
CLAUDE_TIMEOUT_SECONDS=900
CLAUDE_MAX_TURNS_ASK=6
CLAUDE_MAX_TURNS_CODE=10

# 4) Путь к Claude CLI. Если команда claude доступна глобально, оставь claude.
# Если systemd не видит claude, укажи полный путь, например /home/claudebot/.local/bin/claude
CLAUDE_BINARY=claude

# 5) Опционально. Если оставить пустым, Claude Code использует твой логин Claude Max/Pro после claude login.
# Не заполняй для Max-подписки. Заполняй только если хочешь отдельный API-биллинг.
# ANTHROPIC_API_KEY=sk-ant-...

# 6) Опционально. low/medium/high/xhigh/max, если твоя версия Claude Code это поддерживает.
CLAUDE_EFFORT=
